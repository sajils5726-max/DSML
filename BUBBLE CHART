import matplotlib.pyplot as plt

x = [5, 7, 8, 2, 17, 2, 9, 4, 11, 13]
y = [99, 86, 87, 88, 100, 86, 103, 87, 94, 78]
sizes = [40, 60, 80, 100, 120, 140, 160, 180, 200, 220]

